{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": ["dependencies"],
  "rangeStrategy": "pin",
  "packageRules": [
    {
      "description": "Group Spring Boot and Spring Cloud updates",
      "matchPackageNames": [
        "org.springframework**",
        "io.spring**"
      ],
      "groupName": "spring",
      "groupSlug": "spring"
    },
    {
      "description": "Group TestContainers updates",
      "matchPackageNames": ["org.testcontainers**"],
      "groupName": "testcontainers",
      "groupSlug": "testcontainers"
    },
    {
      "description": "Group Resilience4j updates",
      "matchPackageNames": ["io.github.resilience4j**"],
      "groupName": "resilience4j",
      "groupSlug": "resilience4j"
    },
    {
      "description": "Group Flyway updates",
      "matchPackageNames": ["org.flywaydb**"],
      "groupName": "flyway",
      "groupSlug": "flyway"
    },
    {
      "description": "Group MapStruct updates",
      "matchPackageNames": ["org.mapstruct**"],
      "groupName": "mapstruct",
      "groupSlug": "mapstruct"
    }
  ]
}
